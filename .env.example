# Copie para .env e preencha o que quiser usar (pode usar os dois).

# E-mail gratuito via https://web3forms.com
# Crie uma conta, pegue o Access Key e coloque seu e-mail lá.
VITE_WEB3FORMS_ACCESS_KEY=

# Notificação no celular via Telegram (opcional)
# 1. Fale com @BotFather no Telegram e crie um bot
# 2. Pegue o token do bot
# 3. Fale com @userinfobot para pegar seu chat_id
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
